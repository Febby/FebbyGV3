---
// Blog section — rendered from src/data/content.js blogPosts array.
// Slugs link to /blog/[slug] — wire up once the /blog project is integrated.
import { blogPosts } from '../data/content.js';

function formatDate(dateStr) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---
<section id="blog" class="py-24 px-4 bg-surface">
  <div class="max-w-6xl mx-auto">
    <span class="section-label">Blog</span>
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-3 text-theme">From the Blog</h2>
    <p class="text-center text-muted mb-14 max-w-lg mx-auto text-sm md:text-base">
      Practical articles on Shopify, JavaScript, and front-end development.
    </p>
    <div class="grid gap-5 sm:grid-cols-2">
      {blogPosts.map((post) => (
        <article class="card flex flex-col">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-xs font-semibold uppercase tracking-wide text-accent px-2.5 py-1 rounded-full" style="background-color: color-mix(in srgb, var(--color-accent) 12%, transparent);">
              {post.category}
            </span>
            <time class="text-xs text-muted" datetime={post.date}>
              {formatDate(post.date)}
            </time>
          </div>
          <h3 class="text-base font-semibold text-theme mb-2 leading-snug">{post.title}</h3>
          <p class="text-muted text-sm leading-relaxed flex-1">{post.excerpt}</p>
          <a
            href={`/blog/${post.slug}`}
            class="mt-5 text-sm font-semibold text-accent hover:opacity-80 transition-opacity self-start"
          >
            Read more &rarr;
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
