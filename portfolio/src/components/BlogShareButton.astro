---
// Share button for blog post pages. Uses Web Share API with clipboard fallback.
---

<button
  data-share-button
  aria-label="Share this article"
  style="
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    background: transparent;
    cursor: pointer;
    line-height: 1.5;
    transition: background-color 0.15s ease;
  "
>
  Share
</button>

<script is:inline>
  (function () {
    function init() {
      var btn = document.querySelector('[data-share-button]');
      if (!btn) return;

      function setLabel(text) {
        btn.textContent = text;
      }

      function resetAfter(ms) {
        setTimeout(function () { setLabel('Share'); }, ms);
      }

      btn.addEventListener('click', function () {
        var url   = window.location.href;
        var title = document.title;
        var meta  = document.querySelector('meta[name="description"]');
        var text  = (meta && meta.content) ? meta.content : 'Check out this article';

        if (navigator.share) {
          navigator.share({ title: title, text: text, url: url })
            .catch(function (err) {
              console.error('[share] Web Share API failed:', err);
              setLabel('Copy failed');
              resetAfter(2000);
            });
          return;
        }

        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(url)
            .then(function () {
              setLabel('Copied');
              resetAfter(2000);
            })
            .catch(function (err) {
              console.error('[share] Clipboard API failed:', err);
              setLabel('Copy failed');
              resetAfter(2000);
            });
          return;
        }

        console.error('[share] No share API available in this context.');
        setLabel('Copy failed');
        resetAfter(2000);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
