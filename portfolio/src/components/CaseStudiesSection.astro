---
// Case studies section — rendered from src/data/content.js caseStudies array.
import { caseStudies } from '../data/content.js';
---
<section id="projects" class="py-24 px-4 bg-page">
  <div class="max-w-6xl mx-auto">
    <span class="section-label">Work</span>
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-3 text-theme">Case Studies</h2>
    <p class="text-center text-muted mb-14 max-w-lg mx-auto text-sm md:text-base">
      Real problems, practical solutions, and what was learned along the way.
    </p>
    <div class="grid gap-6 md:grid-cols-2">
      {caseStudies.map((study) => (
        <div class="card flex flex-col">
          <h3 class="text-lg font-semibold text-theme mb-5">{study.title}</h3>
          <div class="space-y-4 mb-6 flex-1">
            <div class="pl-3 border-l-2 border-sky-400">
              <span class="text-xs font-semibold uppercase tracking-wide text-accent">Problem</span>
              <p class="text-muted text-sm mt-1 leading-relaxed">{study.problem}</p>
            </div>
            <div class="pl-3 border-l-2 border-emerald-400">
              <span class="text-xs font-semibold uppercase tracking-wide" style="color: #34d399;">Solution</span>
              <p class="text-muted text-sm mt-1 leading-relaxed">{study.solution}</p>
            </div>
            <div class="pl-3 border-l-2 border-violet-400">
              <span class="text-xs font-semibold uppercase tracking-wide" style="color: #a78bfa;">Outcome</span>
              <p class="text-muted text-sm mt-1 leading-relaxed">{study.outcome}</p>
            </div>
          </div>
          <div class="flex flex-wrap gap-2 pt-4 border-t border-theme">
            {study.tech.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
