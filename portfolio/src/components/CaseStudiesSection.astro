---
// Featured projects section — rendered from src/data/content.js projects array.
import { projects } from '../data/content.js';
---
<section id="projects" class="py-24 px-4 bg-page">
  <div class="max-w-6xl mx-auto">
    <span class="reveal section-label" style="--reveal-delay: 0ms">Work</span>
    <h2 class="reveal text-3xl md:text-4xl font-bold text-center mb-3 text-theme" style="--reveal-delay: 80ms">Featured Projects</h2>
    <p class="reveal text-center text-muted mb-14 max-w-lg mx-auto text-sm md:text-base" style="--reveal-delay: 140ms">
      Selected GitHub projects with live demos and source code.
    </p>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {projects.map((project, i) => (
        <div class="reveal card flex flex-col" style={`--reveal-delay: ${200 + i * 100}ms`}>
          <h3 class="text-lg font-semibold text-theme mb-3">{project.title}</h3>
          <p class="text-muted text-sm leading-relaxed mb-6 flex-1">{project.description}</p>
          <div class="flex flex-wrap gap-2 mb-6">
            {project.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
          <div class="flex flex-wrap gap-3 pt-4 border-t border-theme mt-auto">
            {project.demoUrl && (
              <a href={project.demoUrl} class="btn-primary" target="_blank" rel="noopener noreferrer">
                Live Demo
              </a>
            )}
            {project.repoUrl && (
              <a href={project.repoUrl} class="btn-secondary" target="_blank" rel="noopener noreferrer">
                Source Code
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
