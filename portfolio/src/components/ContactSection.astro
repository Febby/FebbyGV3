---
// Contact CTA section — update the href values with your real email, GitHub, and LinkedIn URLs.
---
<section id="contact" class="py-24 px-4" style="background-color: var(--color-surface); border-top: 1px solid var(--color-border);">
  <div class="max-w-2xl mx-auto text-center">
    <span class="section-label">Contact</span>
    <h2 class="text-3xl md:text-4xl font-bold mb-4 text-theme">
      Have a tricky Shopify or front-end issue?
    </h2>
    <p class="text-lg text-muted leading-relaxed mb-10">
      Whether it is a cart drawer conflict, app integration issue, or a small website project,
      I can help investigate the problem and explain the solution clearly.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="mailto:me@febbygunawan.com" class="btn-primary">
        Email Me
      </a>
      <a
        href="https://github.com/Febby"
        target="_blank"
        rel="noopener noreferrer"
        class="px-6 py-3 text-sm font-semibold rounded-full border transition-colors text-theme hover:text-accent"
        style="border-color: var(--color-border); background-color: var(--color-bg);"
      >
        View GitHub
      </a>
      <a
        href="https://www.linkedin.com/in/febby-gunawan-5a596026/"
        target="_blank"
        rel="noopener noreferrer"
        class="px-6 py-3 text-sm font-semibold rounded-full border transition-colors text-muted hover:text-accent"
        style="border-color: var(--color-border);"
      >
        Connect on LinkedIn
      </a>
    </div>
  </div>
</section>