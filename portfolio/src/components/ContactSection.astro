---
// Contact CTA section — update the href values with your real email, GitHub, and LinkedIn URLs.
---
<section id="contact" class="py-24 px-4 bg-gray-900 text-white">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-4">
      Have a tricky Shopify or front-end issue?
    </h2>
    <p class="text-lg text-gray-300 leading-relaxed mb-10">
      Whether it is a cart drawer conflict, app integration issue, or a small website project,
      I can help investigate the problem and explain the solution clearly.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href="mailto:me@febbygunawan.com"
        class="px-6 py-3 bg-blue-600 text-white text-sm font-semibold rounded-full hover:bg-blue-500 transition-colors"
      >
        Email Me
      </a>
      <a
        href="https://github.com/Febby"
        target="_blank"
        rel="noopener noreferrer"
        class="px-6 py-3 bg-white text-gray-900 text-sm font-semibold rounded-full hover:bg-gray-100 transition-colors"
      >
        View GitHub
      </a>
      <a
        href="https://www.linkedin.com/in/febby-gunawan-5a596026/"
        target="_blank"
        rel="noopener noreferrer"
        class="px-6 py-3 border border-gray-600 text-white text-sm font-semibold rounded-full hover:border-gray-400 hover:bg-white/10 transition-colors"
      >
        Connect on LinkedIn
      </a>
    </div>
  </div>
</section>