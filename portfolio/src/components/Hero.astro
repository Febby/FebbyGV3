---
// Hero section — headline, subheadline, CTA buttons, and skill badges.
import background from '../assets/background.png';
import avatar from '../assets/avatar.png';

const badges = ['Shopify', 'JavaScript', 'React', 'WordPress', 'Technical Support'];
---
<section
  class="relative flex flex-col items-center justify-center text-center min-h-[90vh] bg-cover bg-center"
  style={`background-image: url(${background.src});`}
>
  <div class="absolute inset-0 backdrop-blur-[6px]" style="background-color: var(--color-bg); opacity: 0.75;"></div>

  <div class="relative z-10 max-w-3xl px-6 py-20">
    <img
      src={avatar.src}
      alt="Febby Gunawan"
      class="w-28 h-28 md:w-36 md:h-36 rounded-full mx-auto mb-8 ring-4 ring-white ring-offset-2 shadow-xl object-cover"
    />

    <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight tracking-tight text-theme mb-5">
      Front-End Developer &<br class="hidden md:block" />
      <span class="text-accent">Shopify Solutions Engineer</span>
    </h1>

    <p class="text-lg md:text-xl text-muted leading-relaxed max-w-xl mx-auto mb-10">
      I build clean, responsive websites and help eCommerce brands solve tricky
      front-end, cart, and app integration issues.
    </p>

    <div class="flex flex-wrap justify-center gap-3 mb-12">
      <a href="#projects" class="btn-primary">
        View Work
      </a>
      <a
        href="#blog"
        class="px-6 py-3 text-sm font-semibold rounded-full border transition-colors text-theme hover:text-accent"
        style="border-color: var(--color-border); background-color: var(--color-surface);"
      >
        Read Blog
      </a>
      <a
        href="#contact"
        class="px-6 py-3 text-sm font-semibold rounded-full transition-colors text-muted hover:text-accent"
        style="border: 1px solid var(--color-border);"
      >
        Work With Me
      </a>
    </div>

    <div class="flex flex-wrap justify-center gap-2">
      {badges.map((badge) => (
        <span class="tag">{badge}</span>
      ))}
    </div>
  </div>
</section>