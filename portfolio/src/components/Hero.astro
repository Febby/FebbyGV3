---
// Hero section — headline, subheadline, CTA buttons, and skill badges.
import background from '../assets/background.png';
import avatar from '../assets/avatar.png';

const badges = ['Shopify', 'JavaScript', 'React', 'WordPress', 'Technical Support'];
---
<section
  class="relative flex flex-col items-center justify-center text-center min-h-[90vh] bg-cover bg-center"
  style={`background-image: url(${background.src});`}
>
  <div class="absolute inset-0 bg-white/65 backdrop-blur-[6px]"></div>

  <div class="relative z-10 max-w-3xl px-6 py-20">
    <img
      src={avatar.src}
      alt="Febby Gunawan"
      class="w-28 h-28 md:w-36 md:h-36 rounded-full mx-auto mb-8 ring-4 ring-white ring-offset-2 shadow-xl object-cover"
    />

    <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight tracking-tight text-gray-900 mb-5">
      Front-End Developer &<br class="hidden md:block" />
      <span class="text-blue-600">Shopify Solutions Engineer</span>
    </h1>

    <p class="text-lg md:text-xl text-gray-500 leading-relaxed max-w-xl mx-auto mb-10">
      I build clean, responsive websites and help eCommerce brands solve tricky
      front-end, cart, and app integration issues.
    </p>

    <div class="flex flex-wrap justify-center gap-3 mb-12">
      <a
        href="#projects"
        class="px-6 py-3 bg-blue-600 text-white text-sm font-semibold rounded-full shadow-sm hover:bg-blue-700 transition-colors"
      >
        View Work
      </a>
      <a
        href="#blog"
        class="px-6 py-3 bg-white text-gray-800 text-sm font-semibold rounded-full border border-gray-200 shadow-sm hover:bg-gray-50 transition-colors"
      >
        Read Blog
      </a>
      <a
        href="#contact"
        class="px-6 py-3 bg-gray-900 text-white text-sm font-semibold rounded-full shadow-sm hover:bg-gray-700 transition-colors"
      >
        Work With Me
      </a>
    </div>

    <div class="flex flex-wrap justify-center gap-2">
      {badges.map((badge) => (
        <span class="px-3 py-1 text-xs font-medium bg-white/90 text-gray-500 border border-gray-200/80 rounded-full">
          {badge}
        </span>
      ))}
    </div>
  </div>
</section>